# Copy to .env.local for local dev, or set in Railway → Variables.

# Railway Postgres: add a PostgreSQL plugin and reference ${{Postgres.DATABASE_URL}}
# Local Ciright Core (default in scripts if unset):
# DATABASE_URL=postgresql://postgres:password@host:5432/keyra-auth

DATABASE_URL=

# Set automatically on Railway (enables SSL for Postgres)
# RAILWAY_ENVIRONMENT=production

# Optional: skip migrations on start (not recommended for first deploy)
# SKIP_DB_MIGRATE=true

# App port (Railway sets PORT automatically)
# PORT=3000
