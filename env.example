# Copy to .env.local for local dev, or set in Railway → Variables.

# Railway Postgres: add a PostgreSQL plugin and reference ${{Postgres.DATABASE_URL}}
# Local Ciright Core (default in scripts if unset):
# DATABASE_URL=postgresql://postgres:password@host:5432/keyra-auth

DATABASE_URL=

# Set automatically on Railway (enables SSL for Postgres)
# RAILWAY_ENVIRONMENT=production

# Optional: skip migrations on start (not recommended for first deploy)
# SKIP_DB_MIGRATE=true

# App port (Railway sets PORT automatically)
# PORT=3000

# Shared Keyra auth session
# NEXT_PUBLIC_SIMSECURE_AUTH_BACKEND_URL=http://localhost:4000
# NEXT_PUBLIC_KEYRA_GET_STARTED_URL=http://localhost:5173
# When NEXT_PUBLIC_KEYRA_GET_STARTED_URL is local, the return target stays local too.
# When NEXT_PUBLIC_KEYRA_GET_STARTED_URL is remote, localhost falls back to the live Translation callback.
# NEXT_PUBLIC_TRANSLATE_LOGIN_RETURN_URL=https://translate-keyra-production.up.railway.app/login?auth_return=1
# NEXT_PUBLIC_TRANSLATE_LOGIN_POST_AUTH_PATH=/login?auth_return=1
# NEXT_PUBLIC_TRANSLATE_DEV_AUTH_BYPASS=false
# NEXT_PUBLIC_TRANSLATE_DEV_UID=1
